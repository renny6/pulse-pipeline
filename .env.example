# ==============================================================================
# PULSE PIPELINE — .env.example (Safe Public Reference)
# ==============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file — it is in .gitignore.
#
# URL CONVENTION
# ---------------
# The docker-compose.yaml overrides URL variables with Docker-internal DNS names
# (redis, kafka, timescaledb) at runtime. The values below use 'localhost'
# so they work when running Python services directly on the host for debugging.
#
# [MANDATE — zero_trust_security.md §5]
# No credentials are ever hardcoded in source files. Use this file only.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. ANALYTICAL VAULT (TimescaleDB)
# ------------------------------------------------------------------------------
POSTGRES_USER=pulse_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=pulse_analytics

# Host-side connection string (used by Alembic migrations run from the host).
# Inside containers, docker-compose overrides this with timescaledb:5432.
DATABASE_URL_ASYNC=postgresql+asyncpg://pulse_admin:your_secure_password_here@localhost:5444/pulse_analytics

# ------------------------------------------------------------------------------
# 2. GLOBAL GUARD (Redis)
# ------------------------------------------------------------------------------
# docker-compose overrides this with redis://redis:6379/0 inside containers.
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# 3. MESSAGE BUS (Kafka)
# ------------------------------------------------------------------------------
# docker-compose overrides this with kafka:9092 (INTERNAL listener) inside containers.
# From host tooling: localhost:9094 (EXTERNAL listener).
KAFKA_BROKER_URL=localhost:9094
KAFKA_TOPIC_INGESTION=pulse.events.raw
KAFKA_TOPIC_DLQ=pulse.events.dlq

# ------------------------------------------------------------------------------
# 4. EXTERNAL CLOUD API (Alpha Vantage — Free Tier)
# ------------------------------------------------------------------------------
EXTERNAL_API_URL=https://www.alphavantage.co/query
EXTERNAL_API_KEY=your_alphavantage_api_key_here

# ------------------------------------------------------------------------------
# 5. SECURITY & OBSERVABILITY
# ------------------------------------------------------------------------------
# WebSocket JWT signing secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WS_JWT_SECRET=your_64_char_hex_secret_here

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 6. GATEWAY — PHASE 2 (RATE LIMITER & CORS)
# ------------------------------------------------------------------------------
# Token Bucket capacity (max burst size in tokens).
# At 5,000 RPS demo: set to 2000 for noticeable throttling visualisation.
RATE_LIMIT_CAPACITY=2000

# Sustained token refill rate (tokens per second).
RATE_LIMIT_REFILL_RATE=500.0

# CORS: comma-separated list of allowed dashboard origins.
# [MANDATE] Never use "*". Hardcode the exact domain of your React dashboard.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000