# ==============================================================================
# PULSE PIPELINE — .env.example (Safe Public Reference)
# ==============================================================================
# Copy this file to .env and fill in your own values.
# NEVER commit your actual .env file — it is in .gitignore.
#
# [MANDATE — zero_trust_security.md §5]
# No credentials are ever hardcoded in Python files, Dockerfiles, or
# docker-compose.yaml. All sensitive configuration is sourced from this file.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. ANALYTICAL VAULT (TimescaleDB)
# ------------------------------------------------------------------------------
POSTGRES_USER=pulse_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=pulse_analytics

# Async connection string for SQLAlchemy AsyncEngine (Phase 3).
# Inside Docker containers, use 'timescaledb' as the host (Docker DNS).
# For local tooling connecting from host, use 'localhost'.
DATABASE_URL_ASYNC=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@timescaledb:5432/${POSTGRES_DB}

# ------------------------------------------------------------------------------
# 2. GLOBAL GUARD (Redis)
# ------------------------------------------------------------------------------
# Inside Docker containers, use 'redis' as the host (Docker DNS).
# For local tooling connecting from host, use 'localhost'.
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# 3. MESSAGE BUS (Kafka)
# ------------------------------------------------------------------------------
# Inside Docker containers: kafka:9092 (INTERNAL listener)
# From host machine tooling: localhost:9094 (EXTERNAL listener)
KAFKA_BROKER_URL=kafka:9092
KAFKA_TOPIC_INGESTION=pulse.events.raw
KAFKA_TOPIC_DLQ=pulse.events.dlq

# ------------------------------------------------------------------------------
# 4. EXTERNAL CLOUD API (Free-Tier Vendor — Alpha Vantage)
# ------------------------------------------------------------------------------
EXTERNAL_API_URL=https://www.alphavantage.co/query
EXTERNAL_API_KEY=your_alphavantage_api_key_here

# ------------------------------------------------------------------------------
# 5. SECURITY & OBSERVABILITY
# ------------------------------------------------------------------------------
# WebSocket JWT signing secret — must be a cryptographically random 64-char hex.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WS_JWT_SECRET=your_64_char_hex_secret_here

# Python logging level for all services: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO